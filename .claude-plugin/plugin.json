{
  "name": "daemon-manager",
  "description": "Generic daemon lifecycle manager. Start, stop, and monitor persistent background processes with cross-platform IPC.",
  "version": "1.1.2",
  "author": {
    "name": "Thatcher",
    "url": "https://github.com/softwaresoftware-dev"
  },
  "repository": "https://github.com/softwaresoftware-dev/daemon-manager",
  "keywords": [
    "daemon",
    "background",
    "ipc",
    "lifecycle",
    "process"
  ],
  "mcpServers": {
    "daemon-manager": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "server.py"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  }
}
